# 한국어:
# 이 파일은 로컬 실행에 필요한 환경변수 예시입니다. 실제 키를 넣은 `.env`는
# 커밋하지 마세요. 공개 repository에는 이 예시 파일만 포함합니다.
#
# English:
# This file documents the environment variables used for local runs. Never
# commit a real `.env` file. The public repository includes this example only.

# 한국어: LLM provider 선택. 기본값은 anthropic입니다.
# English: LLM provider selection. The default provider is anthropic.
LLM_PROVIDER=anthropic                    # anthropic | openai
LLM_MODEL_ANTHROPIC=claude-opus-4-7       # optional anthropic model override
LLM_MODEL_OPENAI=gpt-5                    # optional openai model override
LLM_MAX_TOKENS=1500                       # provider-agnostic max output tokens

# 한국어: provider API key. 선택한 provider의 키만 필요합니다.
# English: Provider API keys. Only the selected provider's key is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 한국어: 이전 설정명 호환용입니다. LLM_MODEL_ANTHROPIC이 없을 때만 사용됩니다.
# English: Legacy alias. Used only when LLM_MODEL_ANTHROPIC is unset.
ANTHROPIC_MODEL=claude-opus-4-7

# 한국어:
# 아래 키들은 ingestion adapter가 사용하는 선택적 API key입니다. 값이 없으면
# 해당 adapter는 warning을 남기고 빈 결과를 반환합니다.
#
# English:
# The variables below are optional ingestion credentials. When a value is
# missing, the corresponding adapter logs a warning and returns an empty result.

# 한국어: DART OpenAPI. 공시, 자사주, 지분공시, 분할/합병 이벤트에 사용합니다.
# English: DART OpenAPI. Used for filings, buybacks, ownership reports, and split/merger events.
DART_API_KEY=

# 한국어: 한국은행 ECOS API. 금리와 거시계열 수집에 사용합니다.
# English: Bank of Korea ECOS API. Used for rates and macro series.
ECOS_API_KEY=

# 한국어: FRED API. 일부 CSV series는 키 없이도 동작합니다.
# English: FRED API. Some CSV series work without a key.
FRED_API_KEY=

# 한국어: 국회 의안정보시스템 OpenAPI. 과거 법안 metadata 수집에 필요합니다.
# English: National Assembly bill OpenAPI. Required for historical bill metadata.
ASSEMBLY_API_KEY=

# 한국어: 국회 의안 adapter의 RSS/XML fallback입니다. OpenAPI key를 우선 권장합니다.
# English: RSS/XML fallback for the Assembly bill adapter. Prefer the OpenAPI key.
ASSEMBLY_BILLS_URL=

# 한국어:
# 국회 회의록 OpenAPI. 현재 code에는 pipeline skeleton이 있으나 metadata sweep은
# 아직 stub입니다. 향후 endpoint 연결 시 이 키를 사용합니다.
#
# English:
# National Assembly minutes OpenAPI. The pipeline skeleton exists, but the
# metadata sweep is still a stub. This key is documented for the planned wiring.
ASSEMBLY_MINUTES_API_KEY=

# 한국어: 부처별 보도자료 RSS endpoint override입니다.
# English: Per-ministry press-release RSS endpoint overrides.
GOVT_PRESS_MOF_URL=
GOVT_PRESS_FSC_URL=
GOVT_PRESS_FTC_URL=
GOVT_PRESS_MOTI_URL=
GOVT_PRESS_NTS_URL=
GOVT_PRESS_BOK_URL=
GOVT_PRESS_BLUE_HOUSE_URL=
GOVT_PRESS_JUSTICE_URL=

# 한국어:
# KRX adapter용 로컬 CSV 디렉터리입니다. OTP 기반 직접 다운로드와 CSV parsing은
# 아직 TODO이며, 현재는 경로를 기록하는 수준입니다.
#
# English:
# Local CSV directory for the KRX adapter. OTP-based download and CSV parsing
# are still TODO; the current adapter only records the path.
KRX_DATA_PATH=
