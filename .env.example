ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Optional ingestion API keys. If absent, the corresponding adapter logs a
# warning and returns an empty result (the rest of the pipeline still runs).

# DART OpenAPI (https://opendart.fss.or.kr — 무료 가입)
DART_API_KEY=

# Bank of Korea ECOS (https://ecos.bok.or.kr — 무료 가입)
ECOS_API_KEY=

# St. Louis Fed FRED (https://fred.stlouisfed.org — 무료 가입; CSV download도 키 없이 가능)
FRED_API_KEY=
