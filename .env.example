# LLM provider selection. The codebase routes call() / call_json() through
# llm/providers/<provider>.py based on this value. Default: anthropic.
LLM_PROVIDER=anthropic                    # anthropic | openai
LLM_MODEL_ANTHROPIC=claude-opus-4-7       # optional override for anthropic
LLM_MODEL_OPENAI=gpt-5                    # optional override for openai
LLM_MAX_TOKENS=1500                       # provider-agnostic max output tokens

# Provider API keys. Only the one matching LLM_PROVIDER is required.
# The unused provider's SDK is never imported, so leaving its key blank is fine.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Legacy alias for LLM_MODEL_ANTHROPIC (still honored if LLM_MODEL_ANTHROPIC unset).
ANTHROPIC_MODEL=claude-opus-4-7

# Optional ingestion API keys. If absent, the corresponding adapter logs a
# warning and returns an empty result (the rest of the pipeline still runs).

# DART OpenAPI (https://opendart.fss.or.kr — 무료 가입)
# Required for historical 공시 fetch (자사주 소각, 5%보고, 분할/합병, etc.).
DART_API_KEY=

# Bank of Korea ECOS (https://ecos.bok.or.kr — 무료 가입)
ECOS_API_KEY=

# St. Louis Fed FRED (https://fred.stlouisfed.org — 무료 가입; CSV download은 키 없이도 작동)
FRED_API_KEY=

# 국회 의안정보시스템 OpenAPI (data.go.kr/data/15074735 — 무료 가입)
# Required for historical bill fetch back through the 22대 session. Without
# this the assembly adapter returns 0 docs and any catalog target tied to a
# bill (상법 개정, 노란봉투법, 자사주 의무 소각 입법, etc.) cannot be caught
# at all.
ASSEMBLY_API_KEY=

# (Optional) RSS/XML fallback for the assembly adapter. Used only if
# ASSEMBLY_API_KEY is unset. Less reliable; prefer the OpenAPI key.
ASSEMBLY_BILLS_URL=

# 국회 회의록 OpenAPI (data.go.kr/data/3057576 — 무료 가입)
# Used by ingest/assembly_minutes.py for committee debate transcripts.
# Stage 1 metadata sweep is currently a stub that returns [] even with this
# key set — Sprint 1 will wire the actual endpoint. Document the key here so
# operators know it will be consumed once that lands.
ASSEMBLY_MINUTES_API_KEY=

# Government press-release RSS endpoints (one per ministry).
# ingest/govt_press.py reads any of these as overrides on top of its
# DEFAULT_ENDPOINTS table (which currently has every entry empty). Without
# at least the high-impact ones (mof / fsc / blue_house) configured, govt_press
# contributes 0 docs — the adapter just logs "no endpoint configured (skip)"
# for each ministry on every run. RSS only exposes recent items, not archives.
GOVT_PRESS_MOF_URL=
GOVT_PRESS_FSC_URL=
GOVT_PRESS_FTC_URL=
GOVT_PRESS_MOTI_URL=
GOVT_PRESS_NTS_URL=
GOVT_PRESS_BOK_URL=
GOVT_PRESS_BLUE_HOUSE_URL=
GOVT_PRESS_JUSTICE_URL=

# Local CSV directory for the KRX adapter (data.krx.co.kr backend uses an OTP
# token that's not yet implemented). Point to a directory of manually
# downloaded CSVs to feed daily 매매 동향 / 신용잔고 / 공매도잔고 / 종목별 지표
# into the variable layer. Currently the adapter logs the path but parsing is
# also still a TODO — document the var so it's discoverable.
KRX_DATA_PATH=
